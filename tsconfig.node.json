{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["vite.config.ts", "playwright.config.ts", "scripts"]
}
