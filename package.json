{
  "name": "github-issue-dag-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "biome check . && tsc -b --pretty false",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "benchmark:graphs": "bun run scripts/benchmark-large-graphs.ts",
    "verify": "bun run check && bun run test && bun run test:e2e && bun run build"
  },
  "dependencies": {
    "@primer/octicons-react": "19.29.2",
    "@primer/primitives": "11.9.0",
    "@primer/react": "38.31.0",
    "cytoscape": "3.34.0",
    "cytoscape-dagre": "4.0.0",
    "dagre": "0.8.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-is": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/dagre": "0.7.54",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-is": "19.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
